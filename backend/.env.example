# Copy this file to .env and replace every <...> value locally.
# Never commit .env files, OAuth client-secret downloads, access tokens, or webhook secrets.

# Core application settings
APP_NAME=AI Email Guardian
DATABASE_URL=postgresql://<database-user>:<database-password>@localhost:5432/<database-name>
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=<generate-a-long-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_BASE_URL=http://localhost:8000
SQL_ECHO=false

# Generate once with Fernet.generate_key() from cryptography. Store it securely.
MAIL_TOKEN_ENCRYPTION_KEY=<fernet-key>

# Register these exact callback URLs with the matching provider applications.
GMAIL_CLIENT_ID=<google-oauth-client-id>
GMAIL_CLIENT_SECRET=<google-oauth-client-secret>
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/email-accounts/oauth/gmail/callback
OUTLOOK_CLIENT_ID=<microsoft-entra-client-id>
OUTLOOK_CLIENT_SECRET=<microsoft-entra-client-secret>
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/v1/email-accounts/oauth/outlook/callback

# Periodic provider polling is disabled until OAuth and the database are ready.
MAIL_SYNC_ENABLED=false
MAIL_SYNC_INTERVAL_SECONDS=300
MAIL_SYNC_BATCH_SIZE=50
MAIL_SYNC_WORKER_LOCK_ID=914159

# Optional OpenAI-compatible priority classifier. Enable only after privacy review.
LLM_PRIORITY_ENABLED=false
LLM_PRIORITY_BACKEND=langchain
LLM_PRIORITY_API_URL=<https://provider.example/v1/chat/completions>
LLM_PRIORITY_BASE_URL=<https://provider.example/v1>
LLM_PRIORITY_API_KEY=<provider-api-key>
LLM_PRIORITY_MODEL=<model-name>
LLM_PRIORITY_TIMEOUT_SECONDS=15
LLM_PRIORITY_MAX_BODY_CHARACTERS=2000
LLM_PRIORITY_SEND_BODY_PREVIEW=false
LLM_PRIORITY_CLASSIFICATION_VERSION=v1

# WhatsApp Cloud API (all optional; delivery remains disabled until configured).
WHATSAPP_ENABLED=false
WHATSAPP_GRAPH_API_VERSION=<meta-graph-api-version>
WHATSAPP_PHONE_NUMBER_ID=<meta-phone-number-id>
WHATSAPP_ACCESS_TOKEN=<meta-system-user-token>
WHATSAPP_VERIFY_TOKEN=<random-webhook-verification-token>
WHATSAPP_APP_SECRET=<meta-app-secret>
WHATSAPP_PRIORITY_TEMPLATE_NAME=priority_email_alert
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_MAX_DELIVERY_ATTEMPTS=5
