# Core application settings
APP_NAME=AI Email Guardian
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_email_guardian
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_BASE_URL=http://localhost:8000
SQL_ECHO=false

# Generate this once with: Fernet.generate_key() from cryptography. Never rotate it casually.
MAIL_TOKEN_ENCRYPTION_KEY=replace-with-a-fernet-key

# Register these exact callback URLs with the matching provider applications.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/email-accounts/oauth/gmail/callback
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/v1/email-accounts/oauth/outlook/callback

# Periodic provider polling is disabled until OAuth and the database are ready.
MAIL_SYNC_ENABLED=false
MAIL_SYNC_INTERVAL_SECONDS=300
MAIL_SYNC_BATCH_SIZE=50

# Optional OpenAI-compatible deployed priority model endpoint.
LLM_PRIORITY_ENABLED=false
LLM_PRIORITY_API_URL=
LLM_PRIORITY_API_KEY=
LLM_PRIORITY_MODEL=email-priority-classifier
